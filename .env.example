# Google Sheets Monitor Bot — Configuration
# Copy this file to .env and fill in your values

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Get this from the URL: https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# Local Development: Path to your downloaded Google Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY=./service-account.json

# Cloud/Production: Paste the entire content of service-account.json as a string here
GOOGLE_SERVICE_ACCOUNT_JSON=

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Scheduler ────────────────────────────────────────────────────────────────
# Cron expression: "0 * * * *" = every hour on the dot
# To test: use "*/1 * * * *" for every minute
CHECK_INTERVAL_CRON=0 * * * *

# ─── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000

# ─── MongoDB (Optional) ───────────────────────────────────────────────────────
# Required for production persistence on platforms like Render (ephemeral disks)
MONGODB_URI=mongodb+srv://...

